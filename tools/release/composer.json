{
    "name": "nextcloud/release-tools",
    "description": "Release automation domain logic and commands (migrated from .github/scripts)",
    "license": "MIT",
    "type": "project",
    "require": {
        "php": ">=8.3",
        "guzzlehttp/guzzle": "^7.4",
        "knplabs/github-api": "^3.8",
        "symfony/console": "^7"
    },
    "require-dev": {
        "phpunit/phpunit": "^12"
    },
    "autoload": {
        "psr-4": {
            "Nextcloud\\ReleaseTools\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nextcloud\\ReleaseTools\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.3.0"
        }
    }
}
